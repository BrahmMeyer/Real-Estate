<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Go — Rod2Reel Dispatch</title>
<style>
:root { --navy: #0A192F; --pearl: #FDFBF7; --border: #E2E8F0; }
body{background:var(--pearl); color:var(--navy); font-family:sans-serif; text-align:center; padding:40px; display:flex; flex-direction:column; align-items:center; justify-content:center; min-height: 100vh; margin:0;}
.card { background: #fff; padding: 30px; border-radius: 20px; border: 1px solid var(--border); width: 100%; max-width: 350px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
h2 { color: var(--navy); text-transform: uppercase; letter-spacing: 2px; margin-bottom: 20px; font-size: 18px; }
input{padding:14px; width:100%; border-radius: 8px; border: 1px solid var(--border); background: #fff; color: #000; margin-bottom: 15px; box-sizing: border-box; text-align: center; font-size: 16px; outline: none;}
.btn{padding:14px; width:100%; border-radius: 8px; border: 2px solid var(--navy); background: var(--navy); color: #fff; font-weight: bold; cursor: pointer; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 1px; text-decoration: none; display: inline-block;}
.btn-alt { background: transparent; color: var(--navy); }
</style>
</head>
<body>
<div class="card">
    <h2>Dispatch Reel 🎥</h2>
    <input id="input" placeholder="Client Phone or Email" autocomplete="off">
    <button class="btn" onclick="send('whatsapp')">WhatsApp Reveal</button>
    <button class="btn btn-alt" onclick="send('email')">Email Reveal</button>
</div>
<script>
const id = new URLSearchParams(window.location.search).get('id');
function send(type) {
    const val = document.getElementById('input').value.trim();
    if(!val) return;
    const link = `https://go.rod2reel.com/reel.html?id=${id}`;
    const msg = `Your highlight reel is ready! 🎬 View the transformation here: ${link}`;
    if (type === 'whatsapp') {
        let phone = val.replace(/\D/g, '');
        if (phone.startsWith('0') && phone.length === 10) phone = '27' + phone.substring(1);
        window.location.href = `https://wa.me/${phone}?text=${encodeURIComponent(msg)}`;
    } else if (type === 'email') {
        window.location.href = `mailto:${val}?subject=Your Reveal is Ready&body=${encodeURIComponent(msg)}`;
    }
}
</script>
</body>
</html>
